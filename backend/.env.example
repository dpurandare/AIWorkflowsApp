# Copy this file to .env and update the values

# REQUIRED: Generate a strong secret key for JWT signing
# Run: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# Optional: allowed frontend origin for CORS (leave empty to use defaults)
FRONTEND_ORIGIN=

# Optional: shared application data directory
# Standalone default: backend/data
# Docker example: /data
APP_DATA_DIR=./data

# Optional: n8n base URL used to build workflow webhook endpoints
# Examples:
# N8N_BASE_URL=https://n8n.jade-biz.com
# N8N_BASE_URL=https://n8n-2.jade-biz.com
N8N_BASE_URL=https://n8n.jade-biz.com
